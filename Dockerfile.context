# Minimal Docker image for Claude Code context isolation.
# Each context runs inside a container based on this image.
FROM node:22-slim

# Install git (required by Claude Code SDK)
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code SDK globally
RUN npm install -g @anthropic-ai/claude-code

# Create non-root user for running tasks
RUN useradd -m -s /bin/bash runner

# /workspace is the context mount point — only writable directory
RUN mkdir -p /workspace && chown runner:runner /workspace

# Drop to non-root
USER runner
WORKDIR /workspace

# Default entrypoint keeps container alive for docker exec usage
ENTRYPOINT ["tail", "-f", "/dev/null"]
