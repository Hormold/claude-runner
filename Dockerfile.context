# Minimal Docker image for Claude Code context isolation.
# Each context runs inside a container based on this image.
FROM node:22-slim

# Install git (required by Claude Code SDK)
RUN apt-get update && apt-get install -y --no-install-recommends git ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Set up worker app with SDK + tsx as local deps
COPY src/docker-worker.ts /app/docker-worker.ts
COPY tsconfig.json /app/tsconfig.json
RUN cd /app && npm init -y && npm install @anthropic-ai/claude-agent-sdk@latest tsx

# Create non-root user for running tasks
RUN useradd -m -s /bin/bash runner

# /workspace is the context mount point — only writable directory
RUN mkdir -p /workspace && chown runner:runner /workspace

# Drop to non-root
USER runner

# Worker runs from /app (where node_modules live), operates on /workspace
# Worker reads JSON from stdin, writes result to stdout
WORKDIR /app
ENTRYPOINT ["npx", "tsx", "docker-worker.ts"]
