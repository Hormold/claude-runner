# ─── Authentication (required, one of these) ───
CLAUDE_CODE_OAUTH_TOKEN=       # OAuth token (sk-ant-oat*) — from Claude.ai subscription
# ANTHROPIC_API_KEY=           # Or API key (sk-ant-api*) — from console.anthropic.com

# ─── Server ───
PORT=3456
MODEL=claude-sonnet-4-6
MAX_TURNS=10
IDLE_TIMEOUT_MS=300000         # 5 min — kill idle containers after this
DOCKER_IMAGE=claude-runner
AGENT_DIR=./agent
SESSIONS_DIR=./sessions

# ─── Mock API (for testing only) ───
MOCK_API_PORT=3457
MOCK_API_TOKEN=acme-secret-token-42
